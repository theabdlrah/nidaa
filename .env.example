# Nidaa verification auth — COPY THIS FILE TO .env.local AND SET REAL SECRETS.
# .env.local is gitignored; never commit real tokens.
#
# Generate tokens with:  openssl rand -hex 24
# Issue verifier tokens ONLY to trusted actors (NGO coordinators, admins).
# User tokens are for ordinary posters (they cannot verify).

# Admin tokens (comma-separated). Can verify + manage.
NIDAA_ADMIN_TOKENS=change-me-admin-000000000000000000000000

# Verifier tokens (comma-separated). Can verify entries.
NIDAA_VERIFIER_TOKENS=change-me-verifier-000000000000000000000

# Regular user tokens (optional, comma-separated). Cannot verify -> 401.
NIDAA_USER_TOKENS=change-me-user-000000000000000000000000
